___SANDBOXED_JS_FOR_SERVER___

const claimRequest = require('claimRequest');
const runContainer = require('runContainer');
const returnResponse = require('returnResponse');
const setResponseStatus = require('setResponseStatus');
const getRequestMethod = require('getRequestMethod');
const getRequestBody = require('getRequestBody');
const getRequestPath = require('getRequestPath');
const JSON = require('JSON');

if (getRequestPath() !== data.path) {
  return;
}

claimRequest();

if (getRequestMethod() === 'OPTIONS') {
  setResponseStatus(200);
  returnResponse();
  return;
}

const body = getRequestBody();

if (!body) {
  setResponseStatus(400);
  returnResponse();
  return;
}

const order = JSON.parse(body);

let fbp = '';
let fbc = '';
let userAgent = '';
let ipAddress = '';

if (order.note_attributes) {

  for (let i = 0; i < order.note_attributes.length; i++) {

    const attr = order.note_attributes[i];

    if (attr.name === 'fbp') {
      fbp = attr.value || '';
    }

    if (attr.name === 'fbc') {
      fbc = attr.value || '';
    }

    if (attr.name === 'user_agent') {
      userAgent = attr.value || '';
    }

    if (attr.name === 'IP Address') {
      ipAddress = attr.value || '';
    }

  }

}

const items = [];

if (order.line_items) {

  for (let i = 0; i < order.line_items.length; i++) {

    const item = order.line_items[i];

    items.push({
      item_id: '' + (item.product_id || ''),
      item_name: item.title || '',
      price: (item.price || 0) * 1,
      quantity: (item.quantity || 1) * 1
    });

  }

}

const event = {};

event.event_name = 'purchase';

event.transaction_id =
  '' + (order.order_number || order.id || '');

event.currency =
  order.currency || 'BDT';

event.value =
  (order.total_price || 0) * 1;

event.page_location =
  order.order_status_url || '';

event.action_source =
  'website';

event.user_agent =
  userAgent;

event.ip_override =
  ipAddress;

event.fbp = fbp;
event.fbc = fbc;

event['x-fb-ck-fbp'] = fbp;
event['x-fb-ck-fbc'] = fbc;

event.user_data = {

  phone_number:
    order.phone ||
    (order.customer && order.customer.phone) ||
    '',

  address: {

    first_name:
      (order.billing_address &&
        order.billing_address.first_name) ||
      '',

    last_name:
      (order.billing_address &&
        order.billing_address.last_name) ||
      '',

    city:
      (order.billing_address &&
        order.billing_address.city) ||
      '',

    country:
      (order.billing_address &&
        order.billing_address.country_code) ||
      ''

  },

  fbp: fbp,
  fbc: fbc

};

event.items = items;

event['x-fb-cd-content_type'] =
  'product';

runContainer(event, function () {

  setResponseStatus(200);
  returnResponse();

});


